@model MVCFirstBasicApp.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

        @* PAGE HEADER *@
        <div class="mb-4">
            <h1 class="page-heading">
                <i class="fa-solid fa-building me-2"></i>Venue Details
            </h1>
            <p class="text-muted">Viewing the full details for this venue.</p>
        </div>

        @* DETAILS CARD *@
        <div class="card shadow-sm border-0 rounded-3 mb-4">

            @* CARD HEADER BANNER *@
            <div class="card-header venue-card-header rounded-top-3 py-3 px-4">
                <h5 class="mb-0 text-white fw-bold">
                    <i class="fa-solid fa-star me-2"></i>@Model.name
                </h5>
            </div>

            <div class="card-body p-4">

                @* NAME *@
                <div class="detail-row mb-3 pb-3 border-bottom">
                    <div class="detail-label">
                        <i class="fa-solid fa-tag me-2 text-success"></i>
                        <span class="fw-semibold">Venue Name</span>
                    </div>
                    <div class="detail-value mt-1 ps-4 text-muted">
                        @Model.name
                    </div>
                </div>

                @* ADDRESS *@
                <div class="detail-row mb-3 pb-3 border-bottom">
                    <div class="detail-label">
                        <i class="fa-solid fa-location-dot me-2 text-success"></i>
                        <span class="fw-semibold">Address</span>
                    </div>
                    <div class="detail-value mt-1 ps-4 text-muted">
                        @Model.Address
                    </div>
                </div>

                @* CAPACITY *@
                <div class="detail-row mb-2">
                    <div class="detail-label">
                        <i class="fa-solid fa-users me-2 text-success"></i>
                        <span class="fw-semibold">Capacity</span>
                    </div>
                    <div class="detail-value mt-1 ps-4">
                        <span class="badge rounded-pill px-3 py-2 venue-capacity-badge">
                            <i class="fa-solid fa-user me-1"></i>
                            @Model.venueCapacity.ToString("N0") people
                        </span>
                    </div>
                </div>

            </div>
        </div>

        @* ACTION BUTTONS *@
        <div class="d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Back to Venues
            </a>
            <a asp-action="Edit" asp-route-id="@Model.id" class="btn btn-primary px-4">
                <i class="fa-solid fa-pen-to-square me-1"></i> Edit Venue
            </a>
        </div>

    </div>
</div>
